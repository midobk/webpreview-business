# =============================================================================
# Seaway Sites — Environment Variables
# =============================================================================
# Copy this file to `.env.local` (Next.js) or `.env` (scripts) and fill in the
# values for your environment. NEVER commit the populated file — it is
# git-ignored by `.gitignore` (`.env*` rule).
#
# Section guide:
#   1. Admin authentication     — required for /admin dashboard
#   2. Public brand / domain    — optional, used for display only
#   3. Outreach (email)         — optional, for sending emails via AgentMail
#   4. Outreach (SMS)           — optional, Telnyx follow-ups
#   5. Lead discovery           — optional, API keys for richer data
#   6. Prototype generation     — optional, image generation providers
#   7. Agent runtime            — optional, model / telemetry config
#   8. Git / deploy metadata    — informational, copied into commit trailers
#
# All values shown here are placeholders. Replace with real secrets from the
# corresponding provider's dashboard.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Admin authentication  (REQUIRED for /admin to be reachable)
# -----------------------------------------------------------------------------
# bcrypt hash of the admin password. Generated with:
#   node -e "console.log(require('bcrypt').hashSync('your-password', 10))"
# On Vercel this is set per-environment in the project settings, NOT in
# .env.local. Locally, this file or the `.password` file (also git-ignored) is
# read by lib/auth.ts as a fallback.
PASSWORD_HASH=

# Optional: name shown in the admin UI footer / cookie label.
ADMIN_NAME=Dexter


# -----------------------------------------------------------------------------
# 2. Public brand / domain  (OPTIONAL — display only)
# -----------------------------------------------------------------------------
# Brand name displayed on the public site, dashboard, and email signatures.
# Update when the working name is finalized.
BRAND_NAME=Seaway Sites

# Public site URL used for canonical links, OpenGraph tags, and the
# "view live" CTA on prototypes. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://seawaysites.com

# Contact email shown in the site footer / privacy page.
CONTACT_EMAIL=hello@seawayshots.ca


# -----------------------------------------------------------------------------
# 3. Outreach — email  (OPTIONAL — required only to actually send mail)
# -----------------------------------------------------------------------------
# Shared signing secret for private draft-preview links and unsubscribe URLs.
# REQUIRED to build outreach emails: every preview link and unsubscribe URL is
# HMAC-signed with it, and buildOutreach() fails closed when it is absent.
# Must be the SAME value wherever tokens are signed (the outreach runtime)
# and verified (the deployed site — set it in the Vercel project env too).
# Any high-entropy random string works, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# OUTREACH_SIGNING_SECRET is accepted as an alias for this variable.
DRAFT_PREVIEW_SECRET=

# AgentMail API key. Get one at https://agentmail.to after creating an inbox.
# The outreach script (scripts/send-outreach) reads this when sending.
AGENTMAIL_API_KEY=

# Outbound from-address used by the outreach scripts. Must be a verified
# AgentMail inbox. Default placeholder until the inbox is provisioned.
AGENTMAIL_FROM_ADDRESS=preview@agentmail.to

# Reply-to address for outbound outreach. Defaults to CONTACT_EMAIL if unset.
AGENTMAIL_REPLY_TO=


# -----------------------------------------------------------------------------
# 4. Outreach — SMS  (OPTIONAL — Telnyx follow-ups)
# -----------------------------------------------------------------------------
# Telnyx API key. Get one at https://portal.telnyx.com.
TELNYX_API_KEY=

# Telnyx messaging profile ID (required when TELNYX_API_KEY is set).
TELNYX_MESSAGING_PROFILE_ID=

# Telnyx phone number used for SMS follow-ups. Canonical value lives in
# TOOLS.md — copy from there, do not retype.
TELNYX_FROM_NUMBER=+18253953636


# -----------------------------------------------------------------------------
# 5. Lead discovery  (OPTIONAL — only needed for richer discovery)
# -----------------------------------------------------------------------------
# Google Places API key. $200/month permanent free credit. Requires a Google
# Cloud project with billing enabled.
#   https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=

# Optional: restrict Google Places searches to a country code (default: CA).
GOOGLE_PLACES_REGION=CA

# Yelp Fusion API key. Free up to 5,000 calls/day for 30 days; not used in
# MVP after research showed it is trial-only.
YELP_API_KEY=

# Overpass / OpenStreetMap endpoint. Public default is fine; override for
# self-hosted mirrors.
OVERPASS_ENDPOINT=https://overpass-api.de/api/interpreter


# -----------------------------------------------------------------------------
# 5b. Supabase  (OPTIONAL — enables live writes on Vercel)
# -----------------------------------------------------------------------------
# Supabase project URL and service-role key. When set, the dashboard
# PATCH/POST endpoints and the /showcase page read/write live Supabase
# tables instead of the build-time JSON bundle.
#   https://supabase.com/dashboard/project/_/settings/api
#
# Setup steps:
#   1. Create a free Supabase project
#   2. Run scripts/supabase-schema.sql in the SQL editor
#   3. Set NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY below
#   4. Run scripts/migrate_to_supabase.py to import existing JSON data
#   5. Redeploy to Vercel
#
# Without these, the showcase page falls back to the build-time bundle
# (frozen at deploy) and dashboard writes are no-ops on Vercel.
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# 6. Prototype generation — image providers  (OPTIONAL)
# -----------------------------------------------------------------------------
# Google Gemini API key (used by image_generate tool). Free tier available.
GEMINI_API_KEY=

# OpenAI API key (used by image_generate tool with gpt-image-2).
OPENAI_API_KEY=

# OpenRouter API key (used by image_generate tool via OpenRouter).
OPENROUTER_API_KEY=

# MiniMax API key (used by image_generate tool with image-01).
MINIMAX_API_KEY=


# -----------------------------------------------------------------------------
# 7. Agent runtime  (OPTIONAL)
# -----------------------------------------------------------------------------
# Ollama cloud model used for prototype HTML generation. Default value is
# what the cron agent already calls; override for local Ollama.
OLLAMA_MODEL=minimax-m3:cloud

# Optional: explicit ollama host (default http://localhost:11434).
OLLAMA_HOST=http://localhost:11434


# -----------------------------------------------------------------------------
# 8. Git / deploy metadata  (INFORMATIONAL)
# -----------------------------------------------------------------------------
# Git identity used by build cron jobs when committing on behalf of the agent.
GIT_AUTHOR_NAME=Dexter
GIT_AUTHOR_EMAIL=dexter.assistant@agentmail.to

# Vercel deployment target. Used by scripts/deploy.sh (when added).
VERCEL_PROJECT_NAME=webpreview-business
VERCEL_TEAM=midobk
