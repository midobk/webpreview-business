# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# openclaw workspace-setup state + generic templates (project keeps its own IDENTITY.md / SYSTEM.md / AGENT_PLAN.md)
/.openclaw/
/HEARTBEAT.md
/SOUL.md
/USER.md
/TOOLS.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.password

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/

